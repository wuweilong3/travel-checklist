# AI Provider: anthropic, dashscope, or mock
LLM_PROVIDER=dashscope

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Alibaba Cloud DashScope API Key (for Qwen)
# Get your API key from: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# Model name (for DashScope)
# Available models: qwen-plus, qwen-turbo, qwen-max, qwen-math-plus
MODEL_NAME=qwen-plus

# Qwen API Key (alternative)
QWEN_API_KEY=your-qwen-api-key-here
